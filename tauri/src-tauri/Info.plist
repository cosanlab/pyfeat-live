<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- User-visible prompt the OS shows the first time the app
         requests camera access. Required since macOS 10.14. -->
    <key>NSCameraUsageDescription</key>
    <string>Py-feat Live uses your camera to detect facial expressions, landmarks, head pose, gaze, and emotions in real time.</string>

    <!-- Microphone is *not* used by Py-feat Live currently, but listing
         the description keeps the prompt friendly if a future build
         flips it on. -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Py-feat Live does not record audio. This entry is reserved for future features.</string>

    <!-- Legacy from the old WebRTC capture path, which negotiated ICE
         over the host's non-loopback IPs and needed local-network
         access on macOS 15+. The current pipeline captures via
         getUserMedia and POSTs frames to the loopback (127.0.0.1)
         sidecar, which is exempt — so this key is likely vestigial and
         a candidate for removal after verifying no local-network use
         remains. -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Py-feat Live uses local network access to route webcam frames from the camera to its embedded analysis engine. No data leaves your machine.</string>
  </dict>
</plist>
