{
  "name": "pyfeatlive",
  "version": "0.0.1",
  "description": "An interactive demo for py-feat.",
  "author": "Eshin Jolly & Luke Chang",
  "contributors": [
    {
      "name": "Eshin Jolly",
      "email": "eshin.jolly@dartmouth.edu",
      "url": "https://eshinjolly.com/"
    },
    {
      "name": "Luke Chang",
      "email": "luke.j.chang@dartmouth.edu",
      "url": "https://cosanlab.com/"
    }
  ],
  "homepage": "https://py-feat.org/",
  "license": "MIT",
  "private": true,
  "main": "src/main.js",
  "build": {
    "productName": "PyFeatLive",
    "appId": "com.cosanlab.pyfeatlive",
    "mac": {
      "icon": "/Users/lukechang/Github/pyfeat-live/logos/pyfeat_logo_green_shadow.icns",
      "category": "public.app-category.education",
      "target": {
        "target": "default",
        "arch": [
          "arm64",
          "x64"
        ]
      },
      "hardenedRuntime": true,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "type": "distribution",
      "identity": "S368GH6KF7"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "/Users/lukechang/Github/pyfeat-live/logos/pyfeat_logo_green_shadow.ico"
    },
    "files": [
      "app/**/*",
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "resources"
    },
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": null
  },
  "scripts": {
    "start": "node scripts/start.js",
    "build": "webpack --config=scripts/webpack.app.config.js --env=production && electron-builder",
    "dist": "electron-builder --mac"
  },
  "dependencies": {
    "@electron/osx-sign": "^1.0.5",
    "electron-squirrel-startup": "^1.0.0",
    "env": "^0.0.2",
    "fs-jetpack": "^5.1.0",
    "promise-delegate": "^1.0.1"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^5.10.0",
    "webpack-node-externals": "^3.0.0"
  }
}